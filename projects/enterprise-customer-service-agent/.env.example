# Chat model local runtime config.
# Copy this file to .env and fill secrets locally. Do not commit .env.

SPRING_AI_MODEL_CHAT=openai
CUSTOMER_AGENT_CHAT_MODEL_ENABLED=true
CUSTOMER_AGENT_CHAT_OPENAI_API_KEY=<your-deepseek-api-key>
CUSTOMER_AGENT_CHAT_OPENAI_BASE_URL=https://api.deepseek.com
CUSTOMER_AGENT_CHAT_OPENAI_MODEL=deepseek-v4-flash
CUSTOMER_AGENT_CHAT_OPENAI_TEMPERATURE=0.2

# Day 18 RAG / pgvector local runtime config.
# Keep defaults for deterministic local tests. Enable these only after PostgreSQL is running.
SPRING_AI_MODEL_EMBEDDING=none
CUSTOMER_AGENT_KNOWLEDGE_EMBEDDING_MODE=local
CUSTOMER_AGENT_KNOWLEDGE_VECTOR_STORE_TYPE=simple
CUSTOMER_AGENT_PGVECTOR_DIMENSIONS=1536

# Enable these when CUSTOMER_AGENT_KNOWLEDGE_EMBEDDING_MODE=model.
# Bailian / DashScope text embeddings use OpenAI-compatible API.
# Prefer the workspace-specific endpoint from Bailian console when available:
# https://<your-workspace-id>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# Do not point embedding base URL to DeepSeek unless DeepSeek adds a real embeddings endpoint.
CUSTOMER_AGENT_EMBEDDING_OPENAI_API_KEY=<your-dashscope-api-key>
CUSTOMER_AGENT_EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CUSTOMER_AGENT_EMBEDDING_OPENAI_MODEL=text-embedding-v4
CUSTOMER_AGENT_EMBEDDING_DIMENSIONS=1536

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:15432/customer_agent
SPRING_DATASOURCE_USERNAME=customer_agent
SPRING_DATASOURCE_PASSWORD=customer_agent_dev
