<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="customer-agent-app"/>

    <property name="LOG_LEVEL_APP" value="${LOG_LEVEL_APP:-INFO}"/>
    <property name="LOG_LEVEL_ROOT" value="${LOG_LEVEL_ROOT:-INFO}"/>
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
    <property name="LOG_FILE_NAME" value="${LOG_FILE_NAME:-customer-agent-app.log}"/>
    <property name="LOG_FILE_MAX_SIZE" value="${LOG_FILE_MAX_SIZE:-100MB}"/>
    <property name="LOG_FILE_MAX_HISTORY" value="${LOG_FILE_MAX_HISTORY:-30}"/>
    <property name="LOG_FILE_TOTAL_SIZE_CAP" value="${LOG_FILE_TOTAL_SIZE_CAP:-5GB}"/>
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%level app=${APP_NAME} pid=${PID:-} thread=%thread traceId=%X{traceId:-} requestId=%X{requestId:-} tenantId=%X{tenantId:-} logger=%logger{40} msg=%replace(%msg){'[\r\n]+',' '}%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="com.example.customer" level="${LOG_LEVEL_APP}"/>
    <logger name="org.springframework.ai" level="${LOG_LEVEL_SPRING_AI:-INFO}"/>
    <logger name="org.springframework.web" level="${LOG_LEVEL_SPRING_WEB:-INFO}"/>

    <springProfile name="file-log">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE_NAME}</file>
            <encoder>
                <charset>UTF-8</charset>
                <pattern>${CONSOLE_PATTERN}</pattern>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/archive/customer-agent-app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
                <maxHistory>${LOG_FILE_MAX_HISTORY}</maxHistory>
                <totalSizeCap>${LOG_FILE_TOTAL_SIZE_CAP}</totalSizeCap>
            </rollingPolicy>
        </appender>

        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="!file-log">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
